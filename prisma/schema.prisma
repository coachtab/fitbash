generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model WaitlistSignup {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  locale    String?
  source    String   @default("direct")
  consentAt DateTime
  createdAt DateTime @default(now())

  @@map("waitlist_signups")
}

// One vote per IP enforced via the unique constraint on ipHash.
// IPs are hashed server-side with DUEL_VOTE_SALT before storage — raw IPs are
// never written to disk so we don't process personal data under GDPR Art. 4(1).
model DuelVote {
  id        Int      @id @default(autoincrement())
  ipHash    String   @unique
  choice    String
  createdAt DateTime @default(now())

  @@index([choice])
  @@map("duel_votes")
}
