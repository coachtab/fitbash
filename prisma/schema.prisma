generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model WaitlistSignup {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  locale    String?
  source    String   @default("direct")
  consentAt DateTime
  createdAt DateTime @default(now())

  @@map("waitlist_signups")
}
